# ==============================================
# AI代码审查Agent-LangGraph版-GitLab 配置文件
# 复制此文件为 conf/.env 并填入你的密钥
# ==============================================

# 服务端口
SERVER_PORT=5001

# 时区
TZ=Asia/Shanghai

# 大模型供应商, 支持 deepseek 和 openai
LLM_PROVIDER=deepseek

# DeepSeek 配置
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_MODEL=deepseek-v4-flash

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_MODEL=gpt-4o-mini

# 支持 review 的文件扩展名
SUPPORTED_EXTENSIONS=.c,.cc,.cpp,.cs,.css,.cxx,.go,.h,.hh,.hpp,.hxx,.java,.js,.jsx,.md,.php,.py,.sql,.ts,.tsx,.vue,.yml

# 每次 Review 的最大 Token 数
REVIEW_MAX_TOKENS=10000

# Review 风格: professional | sarcastic | gentle | humorous
REVIEW_STYLE=professional

# GitLab 配置
GITLAB_URL=http://your-gitlab-host:8083
GITLAB_ACCESS_TOKEN=glpat-your-gitlab-token

# 开启 Push Review (push 事件触发代码审查)
PUSH_REVIEW_ENABLED=1

# 开启仅审查受保护分支 MR
MERGE_REVIEW_ONLY_PROTECTED_BRANCHES_ENABLED=0

# 日志配置
LOG_FILE=log/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3
LOG_LEVEL=DEBUG

# Dashboard 登录
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin